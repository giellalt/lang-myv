! N-KIN ;

!LEXICON N-KIN_TINGE
!@P.POS.N@!+Sem/Kin:@P.POS.N@ NMN_TINGE ;
! N-KIN ;
!LEXICON N-KIN_VELE_IS-KE-DIM
!@P.POS.N@!+Sem/Kin+Der/ke+Der/Dimin:@P.POS.N@ N-KIN_VELE ;
LEXICON N-KIN_VELE_IS-NE-DIM
@P.POS.N@+Sem/Kin+Der+Der/Dimin+N:@P.POS.N@%>Рқ1Рө N-KIN_VELE ;
LEXICON N-KIN_VELE
@P.POS.N@+Sem/Kin:@P.POS.N@ NMN_KUDO ;
 N-KIN ;
!LEXICON N-KIN_PIZE2_IS-NE-DIM
!@P.POS.N@!+Sem/Kin+Der+Der/Dimin+N:@P.POS.N@ N-KIN_PIZE2 ;
!LEXICON N-KIN_PIZE2
!@P.POS.N@!+Sem/Kin:@P.POS.N@ NMN_KUDO ;
! N-KIN ;

LEXICON N_KUDO_no_comp
@U.COMPOUND.NO@@D.COMPOUND.YES@:@U.COMPOUND.NO@@D.COMPOUND.YES@ N_KUDO ;

LEXICON N_RELAT_KUDO
@U.COMPOUND.NO@@D.COMPOUND.YES@+Relat:@U.COMPOUND.NO@@D.COMPOUND.YES@ N_KUDO ;
LEXICON N-KIN_KUDO
@P.POS.N@+Sem/Kin:@P.POS.N@ NMN_KUDO ;
 N-KIN ;


