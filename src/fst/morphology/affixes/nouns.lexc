+Sg+Abe+Def+Use/NG+Err/Orth+Dial/NW:%>РІСӮ{РҫРөСҚ}РјРһ1%>%>СҒСӮСҢ%> N2Dem-SE ; ! _СҢ_ retension through double %>%>
+Sg+Abe+Def+Use/NG+Err/Orth+Dial/NW+Err/Orth-stem-soft-should-be-0:%^SoftRetain%>СӮРөРјРһ1%>%>СҒСӮСҢ%> N2Dem-SE ; ! _СҢ_ retension through double %>%>

+Pl+Gen+Def:%>СӮРҪР•3%>РҪСҢ%> N2Dem-SE ; ! _СҢ_ retension through double %>%>

+Pl+Ela+Def:%>СӮРҪР•3%>СҒСӮСҚ N2Dem-SE ;
+Pl+Ine+Def:%>СӮРҪР•3%>СҒСҚ N2Dem-SE ;
+Pl+Prl+Def:%>СӮРҪР•3%>Р“2Р° N2Dem-SE ;
+Pl+Cmpr+Def:%>СӮРҪР•3%>СҲРәР° N2Dem-SE ;
+Pl+Abe+Def:%>СӮРҪР•3%>РІСӮРөРјРө N2Dem-SE ;
+Pl+Tra+Def:%>СӮРҪР•3%>РәСҒ N2Dem-SE ;!CheckME 2019-01-25
+Pl+Tra+Def:%>СӮРҪР•3%>РәСҒСҚ N2Dem-SE ;


