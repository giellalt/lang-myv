LEXICON SG_NOM_DEF
!!вӮ¬gt-norm: Noun singular nominative definite
!!вӮ¬ РәР°Р»РҫСҒСҢ: РәР°Р»+N+Sg+Nom+Def
!!вӮ¬ РәР°Р»РҫСҒСҢРәР°Рә: РәР°Р»+N+Sg+Nom+Def+Foc/Р“Р°Рә
!!$ РәР°Р»РҫСҒСҢРіР°Рә: РәР°Р»+N+Sg+Nom+Def+Foc/Р“Р°Рә
@U.DECL-NX.SG@@U.CX.NOM@+Sg+Nom+Def:@U.DECL-NX.SG@@U.CX.NOM@%>{РҫРөСҚГҳ}СҒСҢ NounEnd_K ;
@U.DECL-NX.SG@@U.CX.NOM@+Sg+Nom+Def:@U.DECL-NX.SG@@U.CX.NOM@%>{РҫРөСҚГҳ}СҒСҢ CLT/COP_SG ;
@U.DECL-NX.SG@@U.CX.NOM@+Use/NG+Err/Orth-no-linking-vowel+Dial/NW+Sg+Nom+Def:@U.DECL-NX.SG@@U.CX.NOM@%>%^NoLinkVowСҒСҢ NounEnd_K ;
@U.DECL-NX.SG@@U.CX.NOM@+Use/NG+Err/Orth-no-linking-vowel+Dial/NW+Sg+Nom+Def:@U.DECL-NX.SG@@U.CX.NOM@%>%^NoLinkVowСҒСҢ CLT/COP_SG ;

!LEXICON MWN_SG_NOM_DEF
!!вӮ¬gt-norm: Noun singular nominative definite
!!вӮ¬ РҝР°РәСҒСҸСҒРҫСҒСҢ: РҝР°РәСҒСҸ+N+SP+Ine+Indef+Der+Der/MWN+N+Sg+Nom+Def
!!вӮ¬ РҝР°РәСҒСҸСҒРҫСҒСҢРәР°Рә: РҝР°РәСҒСҸ+N+SP+Ine+Indef+Der+Der/MWN+N+Sg+Nom+Def+Foc/Add
!!$ РҝР°РәСҒСҸСҒРҫСҒСҢРіР°Рә: РҝР°РәСҒСҸ+N+SP+Ine+Indef+Der+Der/MWN+N+Sg+Nom+Def+Foc/Add
!@U.DECL-NX.SG@@U.CX.NOM@+Sg+Nom+Def:@U.DECL-NX.SG@@U.CX.NOM@%>{РҫРөСҚГҳ}СҒСҢ NounEnd_K ;
!@U.DECL-NX.SG@@U.CX.NOM@+Sg+Nom+Def:@U.DECL-NX.SG@@U.CX.NOM@%>{РҫРөСҚГҳ}СҒСҢ CLT/COP_SG ;
!@U.DECL-NX.SG@@U.CX.NOM@+Use/NG+Err/Orth-no-linking-vowel+Dial/NW+Sg+Nom+Def:@U.DECL-NX.SG@@U.CX.NOM@%>%^NoLinkVowСҒСҢ NounEnd_K ;
!@U.DECL-NX.SG@@U.CX.NOM@+Use/NG+Err/Orth-no-linking-vowel+Dial/NW+Sg+Nom+Def:@U.DECL-NX.SG@@U.CX.NOM@%>%^NoLinkVowСҒСҢ CLT/COP_SG ;


LEXICON SG-GEN-DEF
!!вӮ¬gt-norm: Noun singular genitive definite
!!вӮ¬ РәР°Р»РҫРҪСӮСҢ: РәР°Р»+N+Sg+Gen+Def
!!вӮ¬ РәР°Р»РҫРҪСӮСҢРәР°Рә: РәР°Р»+N+Sg+Gen+Def+Foc/Р“Р°Рә
@U.DECL-NX.SG@@U.CX.GEN@+Sg+Gen+Def:@U.DECL-NX.SG@@U.CX.GEN@%>{РҫРөСҚГҳ}РҪСӮСҢ NounEnd_K ;

LEXICON SG-DAT-DEF
@U.DECL-NX.SG@@U.CX.DAT@+Sg+Dat+Def:@U.DECL-NX.SG@@U.CX.DAT@%>{РҫРөСҚГҳ}РҪСӮРөРҪСҢ NounEnd_K ;
