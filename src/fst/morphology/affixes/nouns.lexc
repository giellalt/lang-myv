!! Possessor indices

!! The Erzya language possessor indices or possessive suffixes may be followed
!! by a number of morpheme types


LEXICON PossPX1
:%> PossMarker-then-Clt ;

LEXICON N_KIN-TYPE-PX-GEN-SG1-SG2
!2022-04-07 N_KIN-TYPE-PX-GEN-SG1 ;
 N_KIN-TYPE-PX-GEN-SG2	;
!LEXICON N_KIN-TYPE-PX-GEN-SG1
!+Sg+Gen+PxSg1:%>{РҫРөСҚГҳ}РҪСҢ K ;
LEXICON N_KIN-TYPE-PX-GEN-SG2
+Sg+Gen+PxSg2:%>{РҫРөСҚГҳ}СӮСҢ K ;

! PossMarker-followed-by-K-possibility
LEXICON PossMarker-then-Clt
!2019-03-29 why is the %> missing?
@U.PossPx.Sg1@+PxSg1:@U.PossPx.Sg1@{РҫРөСҚГҳ}РҪ{Р¬Гҳ} K ;
@U.PossPx.Sg1@+Use/SpellNoSugg+Use/NG+PxSg1:@U.PossPx.Sg1@{РҫРөСҚГҳ}Рј K ;
@U.PossPx.Sg2@+PxSg2:@U.PossPx.Sg2@{РҫРөСҚГҳ}СӮ{Р¬Гҳ} K ;
@U.PossPx.Sg2@+Use/NG+Err/Orth+Dial/W+PxSg2:@U.PossPx.Sg2@{РҫРөСҚГҳ}РҪСӮ{Р¬Гҳ} K ;
@U.PossPx.Sg3@+PxSg3:@U.PossPx.Sg3@{РҫРөСҚГҳ}РҪР·{РҫСҚГҳ} K ;
@U.PossPx.Sg3@+PxSg3+Use/NG+Err/Orth:@U.PossPx.Sg3@{РҫРөСҚГҳ}РҪРҙ{РҫСҚГҳ} K ;
@U.PossPx.Sg3@+PxSg3+Use/NG+Err/Orth:@U.PossPx.Sg3@{РҫРөСҚГҳ}РҪРҙР·{РҫСҚГҳ} K ;
@U.PossPx.Sg3@+PxSg3+Use/NG+Err/Orth+Dial:@U.PossPx.Sg3@{РҫРөСҚГҳ}РҪР·Р° K ;
@U.PossPx.Pl1@+PxPl1:@U.PossPx.Pl1@{РҫРөСҚГҳ}РҪ{РҫРөСҚ}Рә K-lak ;
@U.PossPx.Pl2@+PxPl2:@U.PossPx.Pl2@{РҫРөСҚГҳ}РҪРә K-lak ;
@U.PossPx.Pl3@+PxPl3:@U.PossPx.Pl3@{РҫРөСҚГҳ}СҒСӮ K ;
@U.PossPx.Pl3@+Use/NG+Err/Orth+Dial/SE+PxPl3:@U.PossPx.Pl3@{РҫРөСҚГҳ}СҒРә K-lak ;
@U.PossPx.Pl3@+Use/NG+Err/Orth+Dial/SE+PxPl3:@U.PossPx.Pl3@{РҫРөСҚГҳ}СҒРәРө K ;
@U.PossPx.Pl3@+Use/NG+Err/Orth+Dial/W+PxPl3:@U.PossPx.Pl3@{РҫРөСҚГҳ}РҪСҒСӮ K ;

LEXICON _OSH-PossPX1
@U.PossPx.Sg1@+PxSg1:@U.PossPx.Sg1@%>{РҫРөСҚГҳ}РҪ{Р¬Гҳ}  SecondaryDeclination ;
@U.PossPx.Sg1@+Use/NG+Use/SpellNoSugg+Dial/SE+PxSg1:@U.PossPx.Sg1@%>{РҫРөСҚГҳ}Рј  SecondaryDeclination ;
@U.PossPx.Sg2@+PxSg2:@U.PossPx.Sg2@%>{РҫРөСҚГҳ}СӮ{Р¬Гҳ}  SecondaryDeclination ;
@U.PossPx.Sg2@+Use/NG+Err/Orth+Dial/W+PxSg2:@U.PossPx.Sg2@%>{РҫРөСҚГҳ}РҪСӮ{Р¬Гҳ}  SecondaryDeclination ;
@U.PossPx.Sg3@+PxSg3:@U.PossPx.Sg3@%>{РҫРөСҚГҳ}РҪР·{РҫСҚГҳ}  SecondaryDeclination ;
@U.PossPx.Sg3@+PxSg3+Use/NG+Err/Orth:@U.PossPx.Sg3@%>{РҫРөСҚГҳ}РҪРҙ{РҫСҚГҳ}  SecondaryDeclination ;
@U.PossPx.Sg3@+PxSg3+Use/NG+Err/Orth:@U.PossPx.Sg3@%>{РҫРөСҚГҳ}РҪРҙР·{РҫСҚГҳ}  SecondaryDeclination ;
@U.PossPx.Pl1@+PxPl1:@U.PossPx.Pl1@%>{РҫРөСҚГҳ}РҪ{РҫРөСҚ}Рә  SecondaryDeclination ;
@U.PossPx.Pl2@+PxPl2:@U.PossPx.Pl2@%>{РҫРөСҚГҳ}РҪРә  SecondaryDeclination ;
@U.PossPx.Pl3@+PxPl3:@U.PossPx.Pl3@%>{РҫРөСҚГҳ}СҒСӮ  SecondaryDeclination ;
@U.PossPx.Pl3@+Use/NG+Err/Orth+Dial/NW+PxPl3:@U.PossPx.Pl3@%>{РҫРөСҚГҳ}РҪСҒСӮ  SecondaryDeclination ;



